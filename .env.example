# Copy this file to .env.local and fill in your key. Never commit .env.local.
# Get a free API key at https://finnhub.io/register

# Required: Finnhub API key (server-only — never exposed to the browser).
FINNHUB_API_KEY=

# Optional: Alpha Vantage API key. If set, Alpha Vantage is used as an automatic
# per-ticker FAILOVER when Finnhub rate-limits or errors. Its free OVERVIEW +
# GLOBAL_QUOTE calls return full fundamentals, but the free tier is ~25 req/day.
# Get a free key at https://www.alphavantage.co/support/#api-key.
# Server-only — never exposed to the browser.
ALPHAVANTAGE_API_KEY=

# Do not set NODE_TLS_REJECT_UNAUTHORIZED=0. If a corporate proxy intercepts
# HTTPS, install its CA and use NODE_EXTRA_CA_CERTS instead.

# Optional: maximum tickers accepted per scan, server-side (default 20).
MAX_TICKERS=20

# Optional: client-side input cap. Keep in sync with MAX_TICKERS; this is
# inlined into the browser bundle at build/dev start, so changes need a restart.
NEXT_PUBLIC_MAX_TICKERS=20

# Optional: server-side cache TTL in seconds (default 60). Set 0 to disable.
CACHE_TTL_SECONDS=60

# Recommended for multi-instance/serverless deployments. When both are set,
# instrumentation.ts automatically registers the shared Upstash limiter.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Name of an IP header that YOUR trusted edge overwrites/strips before requests
# reach Next (for example x-forwarded-for on a correctly configured proxy).
# Leave blank if that guarantee does not exist; traffic then shares a global
# anonymous bucket instead of trusting a spoofable header.
RATE_LIMIT_TRUSTED_IP_HEADER=

# Optional secret used to HMAC client identifiers before storing limiter keys.
RATE_LIMIT_KEY_SALT=

# Provider-wide ticker budget shared across all clients and scan/refresh traffic.
# Default 20/minute (roughly 60 Finnhub calls at three calls per ticker).
PROVIDER_TICKER_BUDGET_PER_MINUTE=20
